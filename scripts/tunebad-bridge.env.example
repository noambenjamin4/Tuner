# TuneBad Home Bridge secrets template. Copy to tunebad-bridge.env and fill in.
#   cp scripts/tunebad-bridge.env.example scripts/tunebad-bridge.env
# API_KEY must match the Vercel env DOWNLOADER_HOME_KEY.
API_KEY="paste-a-long-random-hex-key-here"
EDGE_CONFIG_ID="ecfg_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Optional but recommended: a long-lived Vercel access token so the bridge can
# publish its tunnel URL without an interactive `vercel login` that expires.
# Create one at https://vercel.com/account/tokens (scope: your account).
# Leave blank to fall back to the Mac's CLI login.
VERCEL_TOKEN=""
